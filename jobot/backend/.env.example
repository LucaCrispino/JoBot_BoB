# ============================================================
# JoBot Backend — Variabili d'Ambiente di Esempio
# ============================================================
# Copia questo file in .env e compila i valori reali.
# NON committare mai il file .env con valori reali nel repository.

# --- Configurazione App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:8081

# --- LLM Provider ---
# TODO (Milestone 2): configurare il provider LLM preferito
# Opzioni supportate: openai, anthropic, mistral, ollama (locale)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...sostituisci-con-chiave-reale

# --- API Aggregatori Lavoro ---
# TODO (Milestone 2): registrarsi come sviluppatori su ciascuna piattaforma

# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID=...sostituisci
ADZUNA_APP_KEY=...sostituisci
ADZUNA_COUNTRY=it

# InfoJobs: https://developer.infojobs.net/
INFOJOBS_CLIENT_ID=...sostituisci
INFOJOBS_CLIENT_SECRET=...sostituisci

# CareerJet: https://www.careerjet.it/partners/
CAREERJET_LOCALE=it_IT
CAREERJET_AFFID=...sostituisci

# --- Database (Milestone 1) ---
# TODO (Milestone 1): configurare PostgreSQL per la persistenza
DATABASE_URL=postgresql+asyncpg://jobot:password@localhost:5432/jobot_db

# --- Redis (Milestone 1) ---
# TODO (Milestone 1): configurare Redis per sessioni e cache
REDIS_URL=redis://localhost:6379/0

# --- Sicurezza JWT (Milestone 1) ---
# TODO (Milestone 1): generare una chiave segreta forte (es. openssl rand -hex 32)
JWT_SECRET_KEY=...sostituisci-con-stringa-casuale-lunga
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- GDPR ---
AUDIT_LOG_ENABLED=true
PSEUDONYMIZE_PROMPTS=true

# --- Timeout (secondi) ---
HTTP_TIMEOUT=5
