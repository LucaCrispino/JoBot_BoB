# ============================================================
# JoBot Frontend — Variabili d'Ambiente di Esempio
# ============================================================
# Copia questo file in .env e adatta i valori.
# Le variabili Expo pubbliche devono iniziare con EXPO_PUBLIC_

# --- URL del Backend FastAPI ---
# Sviluppo locale (simulatore iOS/Android su macchina locale):
EXPO_PUBLIC_API_URL=http://localhost:8000

# Sviluppo su dispositivo fisico (sostituire con l'IP della tua macchina):
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8000

# TODO (Milestone 3): configurare l'URL di produzione
# EXPO_PUBLIC_API_URL=https://api.jobot.app
